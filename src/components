import React, { useRef, useState } from "react";

type ParsedAddress = {
  recipient: string;
  street: string;
  number: string;
  complement: string;
  neighborhood: string;
  city: string;
  state: string;
  zipCode: string;
  rawText: string;
};

const OCR_API_KEY = "SUA_API_KEY_AQUI";

function extractAddressFromOcr(rawText: string): ParsedAddress {
  const text = (rawText || "").replace(/\r/g, "").trim();

  const lines = text
    .split("\n")
    .map((line) => line.trim())
    .filter(Boolean);

  const result: ParsedAddress = {
    recipient: "",
    street: "",
    number: "",
    complement: "",
    neighborhood: "",
    city: "",
    state: "",
    zipCode: "",
    rawText: text,
  };

  if (!lines.length) return result;

  const streetRegex =
    /^(rua|r\.|avenida|av\.|travessa|tv\.|alameda|estrada|rodovia|praça|praca|largo)\b/i;

  const zipMatch = text.match(/\b\d{5}-?\d{3}\b/);
  if (zipMatch) {
    result.zipCode = zipMatch[0];
  }

  const cityStateMatch =
    text.match(/\b([A-Za-zÀ-ÿ\s]+)\s*-\s*([A-Z]{2})\b/) ||
    text.match(/\b([A-Za-zÀ-ÿ\s]+)\s+([A-Z]{2})\b/);

  if (cityStateMatch) {
    result.city = (cityStateMatch[1] || "").trim();
    result.state = (cityStateMatch[2] || "").trim();
  }

  const streetLine = lines.find((line) => streetRegex.test(line));
  if (streetLine) {
    const numberMatch = streetLine.match(/(?:,|\s)(\d+)\b/);
    result.number = numberMatch?.[1] || "";

    result.street = streetLine
      .replace(/(?:,|\s)\d+\b.*$/, "")
      .trim();
  }

  if (lines[0] && !streetRegex.test(lines[0])) {
    result.recipient = lines[0];
  }

  const neighborhoodLine = lines.find((line) =>
    /centro|bairro|jardim|jd\.|vila|parque/i.test(line)
  );
  if (neighborhoodLine) {
    result.neighborhood = neighborhoodLine.replace(/^bairro[:\-]?\s*/i, "").trim();
  }

  const complementLine = lines.find((line) =>
    /apto|apartamento|bloco|casa|fundos|sala|andar|quadra|lote|complemento/i.test(line)
  );
  if (complementLine) {
    result.complement = complementLine.trim();
  }

  return result;
}

export default function AddressScanner() {
  const videoRef = useRef<HTMLVideoElement | null>(null);
  const canvasRef = useRef<HTMLCanvasElement | null>(null);
  const streamRef = useRef<MediaStream | null>(null);

  const [cameraOpen, setCameraOpen] = useState(false);
  const [loading, setLoading] = useState(false);
  const [preview, setPreview] = useState("");
  const [error, setError] = useState("");
  const [form, setForm] = useState<ParsedAddress>({
    recipient: "",
    street: "",
    number: "",
    complement: "",
    neighborhood: "",
    city: "",
    state: "",
    zipCode: "",
    rawText: "",
  });

  async function openCamera() {
    try {
      setError("");

      const stream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: "environment" },
        audio: false,
      });

      streamRef.current = stream;
      setCameraOpen(true);

      setTimeout(() => {
        if (videoRef.current) {
          videoRef.current.srcObject = stream;
          videoRef.current.play().catch(() => {});
        }
      }, 100);
    } catch (err) {
      console.error(err);
      setError("Não foi possível abrir a câmera.");
    }
  }

  function closeCamera() {
    if (streamRef.current) {
      streamRef.current.getTracks().forEach((track) => track.stop());
      streamRef.current = null;
    }
    setCameraOpen(false);
  }

  function capturePhoto(): Blob | null {
    const video = videoRef.current;
    const canvas = canvasRef.current;

    if (!video || !canvas) return null;

    const width = video.videoWidth;
    const height = video.videoHeight;

    if (!width || !height) return null;

    canvas.width = width;
    canvas.height = height;

    const ctx = canvas.getContext("2d");
    if (!ctx) return null;

    ctx.drawImage(video, 0, 0, width, height);

    const dataUrl = canvas.toDataURL("image/jpeg", 0.9);
    setPreview(dataUrl);

    const arr = dataUrl.split(",");
    const mime = arr[0].match(/:(.*?);/)?.[1] || "image/jpeg";
    const bstr = atob(arr[1]);
    let n = bstr.length;
    const u8arr = new Uint8Array(n);

    while (n--) {
      u8arr[n] = bstr.charCodeAt(n);
    }

    return new Blob([u8arr], { type: mime });
  }

  async function scanImage() {
    try {
      setLoading(true);
      setError("");

      const imageBlob = capturePhoto();

      if (!imageBlob) {
        setError("Não foi possível capturar a foto.");
        return;
      }

      const formData = new FormData();
      formData.append("file", imageBlob, "address.jpg");
      formData.append("language", "por");
      formData.append("isOverlayRequired", "false");
      formData.append("OCREngine", "2");

      const response = await fetch("https://api.ocr.space/parse/image", {
        method: "POST",
        headers: {
          apikey: OCR_API_KEY,
        },
        body: formData,
      });

      const data = await response.json();

      if (!response.ok) {
        throw new Error("Erro ao chamar OCR.");
      }

      if (data.IsErroredOnProcessing) {
        throw new Error(data.ErrorMessage?.[0] || "Erro ao processar imagem.");
      }

      const rawText = data?.ParsedResults?.[0]?.ParsedText || "";

      if (!rawText) {
        throw new Error("Nenhum texto encontrado na imagem.");
      }

      const parsed = extractAddressFromOcr(rawText);

      setForm(parsed);
      closeCamera();
    } catch (err: any) {
      console.error(err);
      setError(err.message || "Erro ao ler imagem.");
    } finally {
      setLoading(false);
    }
  }

  function updateField(field: keyof ParsedAddress, value: string) {
    setForm((prev) => ({
      ...prev,
      [field]: value,
    }));
  }

  function confirmAddress() {
    console.log("Endereço confirmado:", form);
    alert("Endereço confirmado. Agora você pode salvar no sistema.");
  }

  return (
    <div style={styles.container}>
      <h2>Scanner de Endereço</h2>

      {!cameraOpen && (
        <button style={styles.button} onClick={openCamera}>
          Abrir câmera
        </button>
      )}

      {cameraOpen && (
        <div style={styles.block}>
          <video ref={videoRef} autoPlay playsInline style={styles.video} />
          <canvas ref={canvasRef} style={{ display: "none" }} />

          <div style={styles.row}>
            <button style={styles.button} onClick={scanImage} disabled={loading}>
              {loading ? "Lendo..." : "Capturar e ler"}
            </button>

            <button style={styles.buttonSecondary} onClick={closeCamera} disabled={loading}>
              Fechar
            </button>
          </div>
        </div>
      )}

      {preview && (
        <div style={styles.block}>
          <p>Prévia:</p>
          <img src={preview} alt="Prévia" style={styles.image} />
        </div>
      )}

      <div style={styles.block}>
        <input
          style={styles.input}
          placeholder="Destinatário"
          value={form.recipient}
          onChange={(e) => updateField("recipient", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Rua"
          value={form.street}
          onChange={(e) => updateField("street", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Número"
          value={form.number}
          onChange={(e) => updateField("number", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Complemento"
          value={form.complement}
          onChange={(e) => updateField("complement", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Bairro"
          value={form.neighborhood}
          onChange={(e) => updateField("neighborhood", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Cidade"
          value={form.city}
          onChange={(e) => updateField("city", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="Estado"
          value={form.state}
          onChange={(e) => updateField("state", e.target.value)}
        />
        <input
          style={styles.input}
          placeholder="CEP"
          value={form.zipCode}
          onChange={(e) => updateField("zipCode", e.target.value)}
        />

        <textarea
          style={styles.textarea}
          placeholder="Texto bruto do OCR"
          value={form.rawText}
          onChange={(e) => updateField("rawText", e.target.value)}
        />

        <button style={styles.button} onClick={confirmAddress}>
          Confirmar endereço
        </button>
      </div>

      {error && <p style={styles.error}>{error}</p>}

      <p style={styles.note}>
        Atenção: desse jeito a chave da OCR fica exposta no frontend. Funciona para teste,
        mas em produção o ideal é mover isso para backend ou Supabase Function.
      </p>
    </div>
  );
}

