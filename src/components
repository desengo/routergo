import type { NextApiRequest, NextApiResponse } from "next";

type ParsedAddress = {
  recipient: string;
  street: string;
  number: string;
  complement: string;
  neighborhood: string;
  city: string;
  state: string;
  zipCode: string;
  rawText: string;
  confidence: number;
};

export default async function handler(
  req: NextApiRequest,
  res: NextApiResponse
) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Método não permitido" });
  }

  try {
    const { imageBase64 } = req.body;

    if (!imageBase64) {
      return res.status(400).json({ error: "Imagem não enviada" });
    }

    const apiKey = process.env.OPENAI_API_KEY;

    if (!apiKey) {
      return res.status(500).json({ error: "OPENAI_API_KEY não configurada" });
    }

    const response = await fetch("https://api.openai.com/v1/responses", {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        Authorization: `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: "gpt-4.1-mini",
        input: [
          {
            role: "system",
            content: [
              {
                type: "input_text",
                text:
                  "Você extrai endereços para um sistema logístico. " +
                  "Leia a imagem e devolva apenas JSON válido com os campos: " +
                  "recipient, street, number, complement, neighborhood, city, state, zipCode, rawText, confidence. " +
                  "confidence deve ser um número de 0 a 1. " +
                  "Se algum campo não existir, devolva string vazia.",
              },
            ],
          },
          {
            role: "user",
            content: [
              {
                type: "input_text",
                text: "Leia esta imagem e extraia o endereço completo.",
              },
              {
                type: "input_image",
                image_url: imageBase64,
              },
            ],
          },
        ],
      }),
    });

    const data = await response.json();

    if (!response.ok) {
      console.error(data);
      return res.status(500).json({
        error: data?.error?.message || "Erro na chamada da IA",
      });
    }

    const outputText =
      data?.output_text ||
      data?.output?.[0]?.content?.find((item: any) => item.type === "output_text")?.text ||
      "";

    let parsed: ParsedAddress;

    try {
      parsed = JSON.parse(outputText);
    } catch (err) {
      console.error("Resposta não veio em JSON:", outputText);

      parsed = {
        recipient: "",
        street: "",
        number: "",
        complement: "",
        neighborhood: "",
        city: "",
        state: "",
        zipCode: "",
        rawText: outputText,
        confidence: 0,
      };
    }

    return res.status(200).json({ address: parsed });
  } catch (error) {
    console.error(error);
    return res.status(500).json({ error: "Erro interno no servidor" });
  }
}
